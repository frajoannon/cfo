# ─────────────────────────────────────────────────────────────────
# Template de variables de entorno
# Copia este archivo como ".env" y completa los valores reales.
# NUNCA subas el archivo .env a git.
# En producción (Cloud Run), estas variables vienen de Secret Manager.
# ─────────────────────────────────────────────────────────────────

# Google Cloud
GCP_PROJECT_ID=tu-proyecto-gcp
BQ_DATASET_ID=raw_cliente1

# Shopify
# Obtener en: Shopify Admin → Apps → Develop apps → Tu app → API credentials
SHOPIFY_SHOP_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Mercado Libre
# Obtener en: https://developers.mercadolibre.com → Tu app → Credenciales
# El refresh_token se obtiene completando el flujo OAuth una vez.
ML_CLIENT_ID=1234567890
ML_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ML_REFRESH_TOKEN=TG-xxxxxxxx-xxxxxxxx

# Chipax
# Obtener contactando a soporte@chipax.com solicitando acceso a la API
CHIPAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
